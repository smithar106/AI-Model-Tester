# Required: API keys for the two providers under test / the evaluator.
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional: override the models under test and the meta-evaluator.
# These default to the values below if unset.
CLAUDE_MODEL=claude-sonnet-4-6
DEEPSEEK_MODEL=deepseek-chat
EVAL_MODEL=claude-sonnet-4-6

# DeepSeek uses an OpenAI-compatible API; override the base URL if needed.
DEEPSEEK_BASE_URL=https://api.deepseek.com
